# FarmyCure backend — copy to ".env" and fill in real values.
# Never commit ".env" (secrets). This file is safe to commit.

PORT=5000

# MongoDB Atlas or local: replace user, password, host, and database name
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority

# Use long random strings in production (same JWT_SECRET everywhere that verifies tokens)
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string

# User app URL (password reset emails)
FRONTEND_BASE_URL=http://localhost:5173

# Optional: email (password reset). If unset, API returns a dev reset link in JSON.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="FarmyCure <noreply@example.com>"

# Optional: Razorpay payments
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Optional: contact/trade notification email (Nodemailer)
# EMAIL_SERVICE=gmail
# EMAIL_USER=
# EMAIL_PASS=
